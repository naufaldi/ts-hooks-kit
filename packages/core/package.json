{
  "name": "@ts-hooks-kit/core",
  "version": "0.1.0",
  "private": false,
  "description": "React hook library based on usehooks-ts, upgraded for React 19 compatibility.",
  "license": "MIT",
  "author": "Naufaldi Rafif S",
  "repository": {
    "type": "git",
    "url": "https://github.com/naufaldi/ts-hooks-kit.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/naufaldi/ts-hooks-kit",
  "bugs": {
    "url": "https://github.com/naufaldi/ts-hooks-kit/issues"
  },
  "keywords": [
    "react",
    "hooks",
    "typescript",
    "react-hooks",
    "usehooks-ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist coverage .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@juggle/resize-observer": "^3.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "jsdom": "^26.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rimraf": "^6.0.1",
    "tsdown": "^0.9.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  },
  "engines": {
    "node": ">=20"
  }
}
